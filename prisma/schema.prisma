// RunaSimi - Aprende Quechua (Duolingo-style)
// Prisma schema - Base de datos REAL con múltiples usuarios reales

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Perfil de usuario real (registro con email)
model UserProfile {
  id              String   @id @default(cuid())
  email           String   @unique // correo electrónico del usuario
  password        String   // hash de la contraseña
  browserId       String   @default("") // cookie de sesión
  name            String
  avatar          String   @default("🧑")
  country         String   @default("")
  nativeLanguage  String   @default("es")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  state       UserState?
  survey      UserSurvey?
  lessons     LessonProgress[]
  achievements AchievementProgress[]
  streakDays  StreakDay[]
}

// Encuesta de personalización (plan del usuario)
model UserSurvey {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Respuestas de la encuesta (almacenadas como strings)
  language        String   @default("quechua")  // lengua elegida
  goal            String   @default("viajar")   // motivo principal
  level           String   @default("principiante") // nivel actual
  pace            String   @default("medio")    // ritmo de aprendizaje
  dailyGoal       Int      @default(30)         // meta diaria de quipus
  reminderTime    String?  // hora preferida para practicar (HH:MM)
  interests       String   @default("")         // intereses separados por coma
  completedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Estado global del usuario (XP/quipus, intis, corazones, racha, liga)
model UserState {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  xp              Int      @default(0)        // quipus tejidos totales
  gems            Int      @default(50)       // intis
  hearts          Int      @default(5)
  maxHearts       Int      @default(5)
  heartsLastRegen DateTime @default(now())
  streak          Int      @default(0)
  lastStreakDate  String?
  dailyXp         Int      @default(0)
  dailyXpDate     String?
  dailyGoal       Int      @default(30)
  league          String   @default("BRONCE")
  leagueXp        Int      @default(0)
  leagueWeek      Int      @default(1)
  frozenCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Progreso por lección
model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  status      String    @default("LOCKED") // LOCKED | ACTIVE | COMPLETED
  crowns      Int       @default(0)
  lastScore   Int       @default(0)
  bestScore   Int       @default(0)
  completedAt DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
}

// Progreso de logros
model AchievementProgress {
  id            String    @id @default(cuid())
  userId        String
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  progress      Int       @default(0)
  target        Int       @default(1)
  unlockedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, achievementId])
}

// Historial de días con racha
model StreakDay {
  id        String   @id @default(cuid())
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  xp        Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}
